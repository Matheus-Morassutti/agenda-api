# Application
APP_PORT=8000

# MySQL database used by the Java API
DB_HOST=localhost
DB_PORT=3306
DB_NAME=agenda_db
DB_USER=agenda_user
DB_PASSWORD=agenda_password

# RabbitMQ messaging
RABBIT_HOST=localhost
RABBIT_PORT=5672

# Docker Compose host ports
MYSQL_PORT=3306
PHPMYADMIN_PORT=8081
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MySQL root account used only by the database container
MYSQL_ROOT_PASSWORD=root_password
